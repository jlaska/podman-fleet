{
  "name": "podman-fleet",
  "displayName": "Podman Fleet",
  "description": "Kubernetes fleet management extension for Podman Desktop using Cluster API",
  "version": "0.1.0",
  "icon": "icon.png",
  "publisher": "jlaska",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "build": "concurrently \"pnpm --filter frontend build\" \"pnpm --filter helloworld build\"",
    "watch": "concurrently \"pnpm --filter frontend watch\" \"pnpm --filter helloworld watch\"",
    "format:check": "prettier --check \"**/src/**/*.{ts,svelte}\"",
    "format:fix": "prettier --write \"**/src/**/*.{ts,svelte}\"",
    "lint:check": "eslint . --ext js,ts,tsx",
    "lint:fix": "eslint . --fix --ext js,ts,tsx",
    "svelte:check": "svelte-check",
    "test:backend": "vitest run -r packages/backend --passWithNoTests --coverage",
    "test:frontend": "vitest -c packages/frontend/vite.config.js run packages/frontend --passWithNoTests --coverage",
    "test:shared": "vitest run -r packages/shared --passWithNoTests --coverage",
    "test": "pnpm run test:backend && pnpm run test:shared && pnpm run test:frontend",
    "typecheck:shared": "tsc --noEmit --project packages/shared",
    "typecheck:frontend": "tsc --noEmit --project packages/frontend",
    "typecheck:backend": "tsc --noEmit --project packages/backend",
    "typecheck": "pnpm run typecheck:shared && pnpm run typecheck:frontend && pnpm run typecheck:backend"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.1.0",
    "@typescript-eslint/parser": "^8.0.1",
    "@vitest/coverage-v8": "^3.1.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "eslint-import-resolver-custom-alias": "^1.3.2",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-etc": "^2.0.3",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-no-null": "^1.0.2",
    "eslint-plugin-redundant-undefined": "^1.0.0",
    "eslint-plugin-sonarjs": "^1.0.4",
    "prettier": "^3.3.3",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^5.36.14",
    "svelte-check": "^3.8.5",
    "typescript": "5.5.4",
    "vite": "7.1.11",
    "vitest": "^3.2.4"
  },
  "workspaces": [
      "packages/*",
      "tests/*"
    ],
  "dependencies": {
    "js-yaml": "^4.1.1"
  },
  "packageManager": "pnpm@9.0.0"
}
